# Fractal Vortex Chain Mainnet Configuration
NETWORK_MODE=mainnet
CHAIN_ID=fractal-vortex-mainnet
GENESIS_FILE=mainnet-genesis.json

# Network Configuration
P2P_PORT=8333
RPC_PORT=8332
RPC_HOST=0.0.0.0
MAX_PEERS=125

# Mining Configuration
MINING_ENABLED=true
MINER_ADDRESS=0x1000000000000000000000000000000000000000
MINING_THREADS=4
DIFFICULTY_TARGET=600

# Security Configuration
SECURITY_LEVEL=high
AUDIT_ENABLED=true
MONITORING_ENABLED=true
CHAOS_TESTING_ENABLED=false

# Storage Configuration
DATA_DIR=/opt/fvc/data
LOG_LEVEL=info
LOG_FILE=/opt/fvc/logs/fvc.log

# Fractal Parameters
FRACTAL_LEVELS=5
ENERGY_THRESHOLD=2.0
VORTEX_PATTERN=1,2,4,8,7,5
GOLDEN_RATIO=1.618033988749895

# Performance
MAX_BLOCK_SIZE=8388608
BLOCK_TIME_TARGET=600
HALVING_INTERVAL=210000
DIFFICULTY_ADJUSTMENT=2016

# API Configuration
API_ENABLED=true
API_CORS_ENABLED=true
API_RATE_LIMIT=1000

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION=168